{
  "name": "coastal-frontend",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "api:sync": "npx openapi-typescript-codegen --input ../banking_backend/schema.yml --output src/api --client axios",
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npx eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "postbuild": "echo '✅ Build completed successfully!'",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/geolocation": "^8.0.0",
    "@headlessui/react": "^2.2.9",
    "@sentry/browser": "^10.26.0",
    "@sentry/react": "^10.26.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.90.10",
    "@vitejs/plugin-react": "^5.1.1",
    "@xmldom/xmldom": "^0.9.5",
    "amplitude-js": "^8.21.9",
    "autoprefixer": "^10.4.21",
    "axios": "^1.15.0",
    "dompurify": "^3.4.0",
    "emoji-picker-react": "^4.16.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "framer-motion": "^12.38.0",
    "http-proxy-middleware": "^2.0.6",
    "lucide-react": "^0.555.0",
    "postcss": "^8.5.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-hot-toast": "^2.6.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.8.0",
    "recharts": "^3.4.1",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.18",
    "terser": "^5.36.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "whatwg-encoding": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "baseline-browser-mapping": "^2.10.16",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.4.0",
    "mkdirp": "^3.0.1",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.2",
    "typescript-eslint": "^8.50.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.2.4",
    "follow-redirects": "^1.16.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write --ignore-unknown"
    ],
    "*.{js,jsx,json,css,md}": [
      "npx prettier --write --ignore-unknown"
    ]
  }
}
