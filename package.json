{
  "name": "coastal-banking-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd banking_backend && python manage.py runserver localhost:8000",
    "frontend": "cd frontend && npm run dev",
    "frontend:fast": "cd frontend && npx vite",
    "sync": "cd frontend && npm run api:sync",
    "build": "cd frontend && npm install && npm run build",
    "start": "cd frontend && npm start",
    "lint:api": "npx @stoplight/spectral-cli lint banking_backend/schema.yml",
    "prepare": "node -e \"if (process.env.CI === 'true') process.exit(0); process.exit(1)\" || husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "amplitude-js": "^8.21.10"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
